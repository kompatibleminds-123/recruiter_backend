{
  "name": "recruiter-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend MVP for Recruiter Speed Desk parsing and AI workflows.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "portal:dev": "vite --config vite.portal.config.js",
    "portal:build": "vite build --config vite.portal.config.js",
    "portal:stage-assets": "powershell -ExecutionPolicy Bypass -File scripts/portal-stage-assets.ps1",
    "portal:release-check": "npm run portal:build && npm run portal:stage-assets && git status --short public/portal-app",
    "test": "node test/run.js",
    "test:cv-parser-report": "node test/cv-parser-report.js",
    "test:cv-freeze": "node test/cv-hybrid-freeze.spec.js",
    "test:cv-freeze:update": "powershell -Command \"$env:UPDATE_CV_HYBRID_FREEZE='1'; node test/cv-hybrid-freeze.spec.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.872.0",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@vitejs/plugin-react": "^6.0.1",
    "docx": "^9.5.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "vite": "^8.0.7",
    "xlsx": "^0.18.5"
  }
}
